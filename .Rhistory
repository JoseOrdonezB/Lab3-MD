vars_importantes <- listings_clean[, c(
"price",
"accommodates",
"bedrooms",
"bathrooms",
"beds",
"number_of_reviews",
"reviews_per_month",
"review_scores_rating"
)]
cor_matrix <- cor(vars_importantes)
corrplot(cor_matrix,
method = "color",
type = "upper",
tl.cex = 0.8)
boxplot(listings_clean$price,
main="Outliers en el precio",
horizontal=TRUE)
cor(vars_importantes$price, vars_importantes$accommodates)
cor(vars_importantes$price, vars_importantes$bedrooms)
cor(vars_importantes$price, vars_importantes$bathrooms)
plot(listings_clean$accommodates,
listings_clean$price,
pch=20,
cex=0.4,
main="Relación entre capacidad y precio",
xlab="Capacidad del alojamiento",
ylab="Precio")
boxplot(price ~ room_type,
data=listings_clean,
main="Precio por tipo de habitación",
